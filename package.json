{
  "name": "battalion",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter=@battalion/db generate",
    "db:migrate": "pnpm --filter=@battalion/db migrate",
    "db:seed": "pnpm --filter=@battalion/db seed",
    "db:studio": "pnpm --filter=@battalion/db studio"
  },
  "devDependencies": {
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "prettier": "^3.8.1"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "esbuild", "sharp", "unrs-resolver"]
  }
}
